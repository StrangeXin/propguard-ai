  "rules": [
    {
      "type": "daily_loss",
      "value_by_account": {
        "50000": 1000,
        "100000": 2000,
        "150000": 3000
      },
      "unit": "usd",
      "description": "Intraday loss cap that resets every trading day at 5:00 PM CT. Includes both realized and unrealized P/L. Breaching causes liquidation of open positions and cancellation of pending orders, but is NOT a rule violation — account remains eligible.",
      "calculation_base": "equity",
      "reset_time": "17:00 CT",
      "breach_action": "liquidation_and_pause",
      "is_violation": false
    },
    {
      "type": "max_drawdown",
      "value_by_account": {
        "50000": 2000,
        "100000": 3000,
        "150000": 4500
      },
      "unit": "usd",
      "description": "End-of-day trailing drawdown. Moves up with your equity high watermark. Breaching this IS a rule violation — account becomes ineligible for funding.",
      "trailing": true,
      "trailing_type": "end_of_day",
      "calculation_base": "equity_high_watermark",
      "breach_action": "account_violation"
    },
    {
      "type": "position_size",
      "value_by_account": {
        "50000": 5,
        "100000": 10,
        "150000": 15
      },
      "unit": "contracts",
      "description": "Maximum number of standard contracts allowed simultaneously. Micro contracts allowed at 10:1 ratio."
    },
    {
      "type": "trading_hours",
      "value": "CME trading hours",
      "unit": "schedule",
      "description": "Must trade within CME exchange hours. No overnight holding past session close unless specifically allowed."
    }
  ],
  "profit_split": {
    "base": 90,
    "max": 100,
    "unit": "percent",
    "scaling": "First $10K at 100%, then 90% after"
  },
  "sources": [
    "https://help.topstep.com/en/articles/8284197-trading-combine-parameters",
