      "max_micro_contracts": 50
    },
    {
      "size": 100000,
      "currency": "USD",
      "profit_target": 6000,
      "profit_target_pct": 6,
      "max_loss_limit": 3000,
      "max_loss_limit_pct": 3,
      "daily_loss_limit": 2000,
      "daily_loss_limit_pct": 2,
      "max_position_size": 10,
      "max_position_size_unit": "contracts",
      "max_micro_contracts": 100
    },
    {
      "size": 150000,
      "currency": "USD",
      "profit_target": 9000,
      "profit_target_pct": 6,
      "max_loss_limit": 4500,
      "max_loss_limit_pct": 3,
      "daily_loss_limit": 3000,
      "daily_loss_limit_pct": 2,
      "max_position_size": 15,
      "max_position_size_unit": "contracts",
      "max_micro_contracts": 150
    }
